{
  "name": "snapsay",
  "version": "0.1.0",
  "private": true,
  "description": "SnapSay Windows voice input assistant",
  "license": "PolyForm-Noncommercial-1.0.0",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 14231",
    "build": "npm run typecheck && vite build && npx tsc -p tsconfig.electron.json",
    "test": "node scripts/run-tests-with-native-rebuild.cjs",
    "test:watch": "vitest",
    "typecheck": "npx tsc --noEmit && npx tsc -p tsconfig.electron.json --noEmit",
    "rebuild:native": "electron-rebuild -f -o better-sqlite3 --types prod",
    "postinstall": "npm run rebuild:native",
    "electron": "npm run build && electron .",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/setup-windows.ps1",
    "watch-commit": "chokidar \"src/**/*\" -c \"git add . && git commit -m 'auto: code change detected' --allow-empty\""
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "better-sqlite3": "^12.10.0",
    "electron-store": "^10.1.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.0.15",
    "chokidar-cli": "^3.0.0",
    "electron": "^39.2.7",
    "jsdom": "^27.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  },
  "optionalDependencies": {
    "uiohook-napi": "^1.5.4"
  }
}
